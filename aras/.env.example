# ─── ARAS v2 — Environment Variables ──────────────────────────────────
# Copy this file to the project root as .env and fill in your keys.

# ─── API Keys ─────────────────────────────────────────────────────────
OPENAI_API_KEY=
NVIDIA_API_KEY=
GITHUB_TOKEN=
GITHUB_OWNER=
HF_TOKEN=
HF_USERNAME=
CROSSREF_EMAIL=

# ─── Budget ───────────────────────────────────────────────────────────
BUDGET_USD_CEILING=5.0

# ─── Approval Gate ────────────────────────────────────────────────────
# Leave empty for auto-approve (no human gate):
APPROVAL_WEBHOOK_URL=

# To use the ARAS UI buttons for approval:
# APPROVAL_WEBHOOK_URL=http://127.0.0.1:8000/api/approval/webhook

# To use an external system (Slack, custom dashboard):
# APPROVAL_WEBHOOK_URL=https://your-system.com/aras-approval

# Seconds to wait for approval before auto-approving (0=immediate):
APPROVAL_TIMEOUT_SECONDS=300

# ─── Local Model Servers (llama-cpp-python) ───────────────────────────
# Absolute paths to GGUF model files. Leave blank to skip local models.
LOCAL_MODEL_1_PATH=
LOCAL_MODEL_2_PATH=
LOCAL_MODEL_3_PATH=
LOCAL_MODEL_HOST=127.0.0.1
LOCAL_MODEL_PORT_BASE=8100

# ─── Infrastructure ──────────────────────────────────────────────────
RUN_MODE=local
CHROMA_PERSIST_DIR=./chroma_db
REDIS_URL=redis://localhost:6379

# ─── UI ───────────────────────────────────────────────────────────────
UI_HOST=127.0.0.1
UI_PORT=8000
AUTO_OPEN_BROWSER=true

# ─── Tuning ──────────────────────────────────────────────────────────
REVIEW_ROUNDS=3
MAX_EXPERIMENT_TIMEOUT_SECONDS=300
SCRAPE_CACHE_TTL_SECONDS=86400
HEARTBEAT_INTERVAL_SECONDS=30
MEMORY_SNAPSHOT_INTERVAL_SECONDS=900
